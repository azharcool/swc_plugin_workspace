{
  "themeConfig": [
    {
      "target": "base-package",
      "description": "Override only happen in base-package",
      "themeMappings": [
        {
          "file": "signup/page.tsx",
          "type": "page",
          "directive": "server",
          "targets": [
            {
              "type": "Component",
              "directive": "client",
              "themeName": "base",
              "package": "base",
              "action": "",
              "importDeclaration": {
                "source": "@znode/base-package/components/signup",
                "specifiers": [
                  {
                    "type": "ImportSpecifier",
                    "value": "SignUp"
                  }
                ]
              },
              "themes": [
                {
                  "type": "Component",
                  "directive": "client",
                  "themeName": "custom1",
                  "package": "custom1",
                  "action": "",
                  "importDeclaration": {
                    "source": "@znode/custom1-package/component/signup",
                    "specifiers": [
                      {
                        "type": "ImportSpecifier",
                        "value": "SignUp"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "themeNameResolver": {
    "server": {
      "directive": "server-only",
      "importDeclaration": {
        "source": "@znode/utils/theme-resolver/theme-resolver.server",
        "specifiers": [
          {
            "type": "ImportDefaultSpecifier",
            "value": "getThemeCookieServer"
          }
        ]
      },
      "variableDeclaration": {
        "kind": "const",
        "declarations": [
          {
            "type": "VariableDeclarator",
            "id": {
              "type": "Identifier",
              "value": "themeName"
            },
            "init": {
              "type": "AwaitExpression"
            }
          }
        ]
      },
      "variable": {
        "kind": "const",
        "declarations": [
          {
            "name": "themeName",
            "nature": "Await",
            "value": "getThemeCookieServer",
            "arguments": []
          }
        ]
      }
    },
    "client": {
      "directive": "client-only",
      "importDeclaration": {
        "source": "@znode/utils/theme-resolver/theme-resolver.client",
        "specifiers": [
          {
            "type": "ImportDefaultSpecifier",
            "value": "getThemeCookieClient"
          }
        ]
      },
      "variableDeclaration": {
        "kind": "const",
        "declarations": [
          {
            "type": "VariableDeclarator",
            "id": {
              "type": "Identifier",
              "value": "themeName"
            },
            "init": {
              "type": "AwaitExpression"
            }
          }
        ]
      },
      "variable": {
        "kind": "const",
        "declarations": [{
          "name": "themeName",
          "nature": "Await",
          "value": "getThemeCookieClient",
          "arguments": []
        }]
      }
    }
  },
  "debug": true
}
