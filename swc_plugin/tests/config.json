{
  "themeConfig": [
    {
      "target": "base-package",
      "description": "Override only happen in base-package",
      "themeMappings": [
        {
          "file": "signup/page.tsx",
          "nature": "Page",
          "directive": "server",
          "targets": [
            {
              "nature": "Component",
              "directive": "client",
              "themeName": "base",
              "package": "base",
              "action": "",
              "import": {
                "source": "@znode/base-package/components/signup",
                "specifiers": [
                  {
                    "nature": "ImportSpecifier",
                    "value": "SignUp"
                  }
                ]
              },
              "themes": [
                {
                  "nature": "Component",
                  "directive": "client",
                  "themeName": "custom1",
                  "package": "custom1",
                  "action": "",
                  "import": {
                    "source": "@znode/custom1-package/component/signup",
                    "specifiers": [
                      {
                        "nature": "ImportSpecifier",
                        "value": "SignUp"
                      }
                    ]
                  }
                },

                {
                  "nature": "Component",
                  "directive": "client",
                  "themeName": "custom2",
                  "package": "custom2",
                  "action": "",
                  "import": {
                    "source": "@znode/custom2-package/component/signup",
                    "specifiers": [
                      {
                        "nature": "ImportSpecifier",
                        "value": "SignUp"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "themeNameResolver": {
    "server": {
      "directive": "server-only",
      "import": {
        "source": "@znode/utils/theme-resolver/theme-resolver.server",
        "specifiers": [
          {
            "nature": "ImportDefaultSpecifier",
            "value": "getThemeCookieServer"
          }
        ]
      },
      "variable": {
        "kind": "const",
        "declarations": [
          {
            "name": "themeName",
            "nature": "Await",
            "value": "getThemeCookieServer",
            "arguments": []
          }
        ]
      }
    },
    "client": {
      "directive": "client-only",
      "import": {
        "source": "@znode/utils/theme-resolver/theme-resolver.client",
        "specifiers": [
          {
            "nature": "ImportDefaultSpecifier",
            "value": "getThemeCookieClient"
          }
        ]
      },
      "variable": {
        "kind": "const",
        "declarations": [
          {
            "name": "themeName",
            "nature": "Await",
            "value": "getThemeCookieClient",
            "arguments": []
          }
        ]
      }
    }
  },
  "debug": true
}
